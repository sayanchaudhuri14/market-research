api_key = YOUR_KITE_API_KEY
api_secret = YOUR_KITE_API_SECRET

# Zerodha login credentials (used by kite_auth.py for automated token generation)
user_id = YOUR_CLIENT_ID
password = YOUR_ZERODHA_PASSWORD

# The base32 TOTP seed — NOT the 6-digit code.
# Find it in Zerodha: Profile → Password & Security → 2FA → "Can't scan? Enter code manually"
# It looks like: JBSWY3DPEHPK3PXP
totp_secret = YOUR_TOTP_BASE32_SECRET